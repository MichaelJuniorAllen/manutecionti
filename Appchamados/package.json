{
  "name": "appchamados",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "start": "concurrently \"npm:server:dev\" \"npm:client\"",
    "dev": "concurrently \"npm:server:dev\" \"npm:client\"",
    "client": "vite",
    "server": "node server/index.js",
    "server:dev": "nodemon --watch server --ext js,mjs,cjs,json --ignore server/data/database.json --ignore public/uploads/** server/index.js",
    "migrate:json-to-postgres": "node server/scripts/migrate-json-to-postgres.js",
    "build": "vite build",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-easy-crop": "^6.2.2",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2",
    "resend": "^6.17.2",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.14",
    "oxlint": "^1.71.0",
    "vite": "^8.1.1"
  }
}
